{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true}); console.log('removed .next')\"",
    "dev": "next dev",
    "rebuild": "npm run clean && npm run build",
    "build": "next build --webpack",
    "postbuild": "node scripts/copy-standalone-static.mjs",
    "start": "node server.js",
    "start:next": "next start",
    "lint": "eslint"
  },
  "engines": {
    "node": ">=20.9.0 <23"
  },
  "dependencies": {
    "next": "^16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
