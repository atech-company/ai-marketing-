# Laravel API base URL — no trailing slash.
# MUST include http:// or https://. A bare hostname (e.g. api.example.com) is treated as a relative path in the browser.
NEXT_PUBLIC_API_URL=https://aii.atechleb.com

# Production example:
NEXT_PUBLIC_API_URL=https://aii.atechleb.com

# Optional — Meta Share Dialog so users can pick a Facebook Page when sharing (not only personal profile).
# Create an app at https://developers.facebook.com/ and add OAuth redirect: https://YOUR_DOMAIN/share/facebook
# NEXT_PUBLIC_FACEBOOK_APP_ID=
# NEXT_PUBLIC_SITE_URL=https://your-frontend-domain.com
