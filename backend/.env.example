APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Comma-separated browser origins allowed to call the API (CORS). Required for SPA on another domain.
# Production example: CORS_ALLOWED_ORIGINS=https://ai.atechleb.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://ai.atechleb.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=aianalytic
DB_USERNAME=root
DB_PASSWORD=

# SQLite (optional local fallback):
# DB_CONNECTION=sqlite
# # DB_DATABASE=/absolute/path/to/database.sqlite  (or use database/database.sqlite with touch)

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- AI Marketing Discovery ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_REQUEST_TIMEOUT=120

# Crawling (optional overrides)
# CRAWL_MAX_PAGES=8
# CRAWL_HTTP_TIMEOUT=15
# CRAWL_PLAYWRIGHT_TIMEOUT=28
# CRAWL_MIN_TEXT_CHARS=400
# CRAWL_VERIFY_SSL=true
# PLAYWRIGHT_NODE_BINARY=node
# PLAYWRIGHT_SCRIPT_PATH=

# SPA URL (for future Sanctum / CORS tightening)
# FRONTEND_URL=http://localhost:3000
